{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information for the teacher.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" }
      },
      "required": ["uid", "email"]
    },
    "Student": {
      "title": "Student",
      "description": "Information about a student.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "teacherUid": { "type": "string" }
      },
      "required": ["name", "teacherUid"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Details of a scheduled lesson.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "subject": { "type": "string" },
        "notes": { "type": "string" },
        "summary": { "type": "string", "description": "Gemini-generated summary" },
        "teacherUid": { "type": "string" }
      },
      "required": ["studentId", "startTime", "endTime", "teacherUid"]
    },
    "BookingLink": {
      "title": "BookingLink",
      "description": "A link generated for a student to book a lesson.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "workStartTime": { "type": "string", "format": "date-time" },
        "workEndTime": { "type": "string", "format": "date-time" },
        "teacherUid": { "type": "string" },
        "teacherName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "used", "invalid"] },
        "lessonsSnapshot": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["studentId", "studentName", "date", "workStartTime", "workEndTime", "teacherUid", "teacherName", "status"]
    },
    "BookingRequest": {
      "title": "BookingRequest",
      "description": "A request from a student to book a lesson.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "subject": { "type": "string" },
        "notes": { "type": "string" },
        "teacherUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "denied"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "bookingLinkId": { "type": "string" }
      },
      "required": ["studentId", "startTime", "endTime", "teacherUid", "status", "bookingLinkId"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Teacher profiles."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Students managed by the teacher."
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Scheduled lessons."
    },
    "/bookingLinks/{linkId}": {
      "schema": "BookingLink",
      "description": "Generated booking links."
    },
    "/bookingRequests/{requestId}": {
      "schema": "BookingRequest",
      "description": "Pending and processed booking requests."
    }
  }
}
